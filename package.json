{
  "name": "ahem-server",
  "version": "1.0.0",
  "license": "LGPL-3",
  "scripts": {
    "ng": "ng",
    "start": "concurrently --kill-others \"node ahem.js\" \"ng serve --proxy-config proxy.conf.json\"",
    "test": "ng test",
    "testServer": "jest **/*/serverapp.spec.js --runInBand --detectOpenHandles --forceExit --coverage",
    "code-coverage-badges": "jest-coverage-badges",
    "lint": "eslint \"client/**/*.ts\" \"server/**/*.js\"",
    "e2e": "ng e2e",
    "build": "npm install && ng build",
    "buildDev": "npm install && ng build --configuration development",
    "build:ssr": "npm run build:client-and-server-bundles && npm run webpack:server",
    "serve:ssr": "node dist/universalServer --proxy-config proxy.conf.json",
    "build:client-and-server-bundles": "ng build --configuration production && ng run ahem-universal:server:production",
    "webpack:server": "webpack --config webpack.server.config.js --mode production",
    "webpack:backend": "webpack --config webpack.backend.config.js --mode production"
  },
  "jest": {
    "verbose": true,
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/server/app/*.js"
    ],
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "coverageDirectory": "./coverage"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.1.0",
    "@angular/cdk": "^19.1.0",
    "@angular/common": "^19.1.0",
    "@angular/compiler": "^19.1.0",
    "@angular/core": "^19.1.0",
    "@angular/forms": "^19.1.0",
    "@angular/material": "^19.1.0",
    "@angular/platform-browser": "^19.1.0",
    "@angular/platform-browser-dynamic": "^19.1.0",
    "@angular/platform-server": "^19.1.0",
    "@angular/router": "^19.1.0",
    "@angular/ssr": "^19.1.0",
    "@fortawesome/angular-fontawesome": "^0.16.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "angulartics2": "^13.0.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.1",
    "moment": "^2.30.1",
    "mongodb": "^6.12.0",
    "morgan": "^1.10.0",
    "ngx-moment": "^6.0.2",
    "nodemon": "^3.1.9",
    "rxjs": "^7.8.1",
    "smtp-server": "^3.15.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1",
    "winston": "^3.17.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.1.0",
    "@angular-eslint/builder": "^19.0.2",
    "@angular-eslint/eslint-plugin": "^19.0.2",
    "@angular-eslint/eslint-plugin-template": "^19.0.2",
    "@angular-eslint/schematics": "^19.0.2",
    "@angular-eslint/template-parser": "^19.0.2",
    "@angular/cli": "^19.1.0",
    "@angular/compiler-cli": "^19.1.0",
    "@angular/language-service": "^19.1.0",
    "@eslint/js": "^9.17.0",
    "@types/express": "^5.0.0",
    "@types/jasmine": "^5.1.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "jasmine-core": "^5.5.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jest": "^29.7.0",
    "jest-coverage-badges": "^1.1.3",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "mongodb-memory-server": "^10.1.3",
    "nodemailer": "^6.9.16",
    "sass": "^1.83.0",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  }
}
